<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MhfuLookup.App"
    xmlns:toolkit="using:AK.Toolkit.WinUI3">

    <!-- Converters -->
    <local:BoolToVisibilityConverter x:Key="BoolToVis" />
    <local:NullToVisibilityConverter x:Key="NullToVis" />
    <local:NullToVisibleConverter x:Key="NullToVisible" />
    <local:StringToVisibilityConverter x:Key="StringToVis" />
    <local:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis" />
    <local:SignedIntConverter x:Key="SignedInt" />
    <local:SignBrushConverter x:Key="SignBrush" />
    <local:HexToBrushConverter x:Key="HexToBrush" />
    <local:HitzoneBrushConverter x:Key="HitzoneBrush" />
    <local:LocationBrushConverter x:Key="LocationBrush" />
    <local:LocationIconConverter x:Key="LocationIcon" />
    <local:MonsterIconConverter x:Key="MonsterIcon" />
    <local:ItemIconConverter x:Key="ItemIcon" />
    <local:ImageUriConverter x:Key="ImageUri" />
    <local:GuidePartConverter x:Key="GuidePart" />
    <local:AltRowBrushConverter x:Key="AltRowBrush" />
    <local:GatherableConverter x:Key="GatherableVis" />

    <!-- In-game MHFU font (ROM-extracted, Assets/Fonts/mhfu_font.ttf). Applied app-wide:
         AppFontFamily is set on the shell root (inherits to all TextBlocks), and the override
         of ContentControlThemeFontFamily covers templated controls (buttons, combo boxes, etc.). -->
    <FontFamily x:Key="AppFontFamily">ms-appx:///Assets/Fonts/mhfu_font.ttf#MHFU</FontFamily>
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/mhfu_font.ttf#MHFU</FontFamily>

    <!-- Dark palette mirroring the Python app (main.py _dark_palette). -->
    <Color x:Key="WindowBgColor">#1E1E1E</Color>
    <Color x:Key="BaseBgColor">#252525</Color>
    <Color x:Key="AltBgColor">#2A2A2A</Color>
    <Color x:Key="PanelBgColor">#242424</Color>
    <Color x:Key="TextColor">#D4D4D4</Color>
    <Color x:Key="MutedTextColor">#9A9A9A</Color>
    <Color x:Key="AccentColor">#2A5F8F</Color>
    <Color x:Key="HeaderColor">#7A9AB0</Color>
    <Color x:Key="PositiveColor">#5FB85F</Color>
    <Color x:Key="NegativeColor">#C07070</Color>
    <Color x:Key="BorderColor">#3C3C3C</Color>

    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}" />
    <SolidColorBrush x:Key="BaseBgBrush" Color="{StaticResource BaseBgColor}" />
    <SolidColorBrush x:Key="AltBgBrush" Color="{StaticResource AltBgColor}" />
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBgColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}" />
    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource PositiveColor}" />
    <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource NegativeColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <!-- Darker theme-tinted surface behind data tables / detail panes (set live by Appearance). -->
    <SolidColorBrush x:Key="TableBgBrush" Color="#0E0E0E" />

    <!-- Opaque copies of the surface brushes (same theme colours, full alpha). The page surfaces are
         translucent over the menu-art background, but pop-ups (combo drop-downs, flyouts, dialogs)
         must stay solid so their options are readable. Recoloured live by Appearance. -->
    <SolidColorBrush x:Key="BaseBgOpaqueBrush" Color="{StaticResource BaseBgColor}" />
    <SolidColorBrush x:Key="AltBgOpaqueBrush" Color="{StaticResource AltBgColor}" />
    <SolidColorBrush x:Key="PanelBgOpaqueBrush" Color="{StaticResource PanelBgColor}" />
    <SolidColorBrush x:Key="TableBgOpaqueBrush" Color="#0E0E0E" />

    <!-- Make built-in controls follow the app theme. These alias WinUI's control theme resources
         to the app's live background/border brushes (the same instances Appearance recolours), so
         ComboBoxes, their drop-downs, text boxes, flyouts and dialogs match the chosen colour and
         recolour live. (StaticResource ResourceKey="…" creates an alias to the same brush object.) -->
    <!-- ComboBox (closed control + open drop-down) — opaque so selections stay readable over the art. -->
    <StaticResource x:Key="ComboBoxBackground" ResourceKey="BaseBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxBackgroundUnfocused" ResourceKey="BaseBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="AltBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="AltBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxBackgroundDisabled" ResourceKey="PanelBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxDropDownBackground" ResourceKey="AltBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxDropDownBackgroundPointerOver" ResourceKey="BaseBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxDropDownBackgroundPointerPressed" ResourceKey="PanelBgOpaqueBrush" />
    <StaticResource x:Key="ComboBoxBorderBrush" ResourceKey="BorderBrush" />
    <StaticResource x:Key="ComboBoxBorderBrushPointerOver" ResourceKey="BorderBrush" />
    <StaticResource x:Key="ComboBoxBorderBrushPressed" ResourceKey="BorderBrush" />
    <StaticResource x:Key="ComboBoxDropDownBorderBrush" ResourceKey="BorderBrush" />
    <!-- TextBox / search boxes -->
    <StaticResource x:Key="TextControlBackground" ResourceKey="BaseBgBrush" />
    <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="AltBgBrush" />
    <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="AltBgBrush" />
    <StaticResource x:Key="TextControlBackgroundDisabled" ResourceKey="PanelBgBrush" />
    <StaticResource x:Key="TextControlBorderBrush" ResourceKey="BorderBrush" />
    <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="BorderBrush" />
    <!-- Flyouts / menu drop-downs / dialogs — opaque so pop-up content stays readable over the art. -->
    <StaticResource x:Key="FlyoutBackground" ResourceKey="PanelBgOpaqueBrush" />
    <StaticResource x:Key="FlyoutBorderThemeBrush" ResourceKey="BorderBrush" />
    <StaticResource x:Key="MenuFlyoutPresenterBackground" ResourceKey="PanelBgOpaqueBrush" />
    <StaticResource x:Key="MenuFlyoutPresenterBorderBrush" ResourceKey="BorderBrush" />
    <StaticResource x:Key="ContentDialogBackground" ResourceKey="PanelBgOpaqueBrush" />
    <StaticResource x:Key="ContentDialogBorderBrush" ResourceKey="BorderBrush" />

    <!-- Element colors (weapons / resistances). -->
    <SolidColorBrush x:Key="FireBrush" Color="#FF4D2E" />
    <SolidColorBrush x:Key="WaterBrush" Color="#4A9EFF" />
    <SolidColorBrush x:Key="ThunderBrush" Color="#F5C400" />
    <SolidColorBrush x:Key="IceBrush" Color="#7FD8F0" />
    <SolidColorBrush x:Key="DragonBrush" Color="#B060E0" />

    <x:Double x:Key="DetailTitleSize">18</x:Double>
    <x:Double x:Key="SectionTitleSize">14</x:Double>

    <!-- Shared table cell styles -->
    <Style x:Key="HeaderCell" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HeaderBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="6,4" />
    </Style>
    <Style x:Key="BodyCell" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,12,0,4" />
    </Style>

    <!-- Keep list scrollbars in their traditional (expanded) state instead of the auto-hiding thin
         indicator. Targets ListView (not ScrollViewer) on purpose: a global ScrollViewer rule also
         hits inner horizontal-only scrollers (Gathering rows, Monster/Armor wide tables) and forces a
         dead vertical bar onto them. Detail panes set KeepVerticalExpanded explicitly; horizontal
         tables set KeepHorizontalExpanded explicitly. Implicit style is safe without BasedOn for
         WinUI controls (default style comes from metadata). -->
    <Style TargetType="ListView">
        <Setter Property="toolkit:ScrollBarExtensions.KeepVerticalExpanded" Value="True" />
        <!-- Reserve room on the right so item text isn't hidden under the now-always-visible bar. -->
        <Setter Property="Padding" Value="0,0,16,0" />
    </Style>

</ResourceDictionary>
