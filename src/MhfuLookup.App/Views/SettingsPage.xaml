<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    Background="{StaticResource WindowBgBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="10">
            <Grid>
                <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" />
                <Button Content="Restore Defaults" Click="RestoreDefaults_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <TextBlock Text="UI Scale" Foreground="{StaticResource TextBrush}" Margin="0,12,0,0" />
            <ComboBox x:Name="ScaleCombo" Width="160"
                      ItemsSource="{x:Bind ViewModel.Scales}"
                      SelectedItem="{x:Bind ViewModel.SelectedScale, Mode=TwoWay}" />
            <TextBlock Text="Scale changes apply immediately and are remembered next launch."
                       Foreground="{StaticResource MutedTextBrush}" FontStyle="Italic" FontSize="12" />

            <!-- ── Appearance ── -->
            <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource HeaderBrush}" Margin="0,24,0,0" />

            <TextBlock Text="App icon (window &amp; taskbar)" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
            <ComboBox Width="260" MaxDropDownHeight="360"
                      ItemsSource="{x:Bind AppearanceVm.Icons}"
                      SelectedItem="{x:Bind AppearanceVm.SelectedIcon, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:AppIconOption">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Width="22" Height="22" Stretch="Uniform"
                                   Source="{x:Bind Id, Converter={StaticResource MonsterIcon}}" />
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="App colour" Foreground="{StaticResource TextBrush}" Margin="0,10,0,0" />
            <ComboBox Width="200" MaxDropDownHeight="400"
                      ItemsSource="{x:Bind AppearanceVm.Colors}"
                      SelectedItem="{x:Bind AppearanceVm.SelectedColor, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ThemeColorOption">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="20" Height="20" CornerRadius="3" Background="{x:Bind Swatch}" />
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Icon and colour apply immediately and are remembered next launch."
                       Foreground="{StaticResource MutedTextBrush}" FontStyle="Italic" FontSize="12" Margin="0,2,0,0" />

            <!-- ── Tab icons ── -->
            <TextBlock Text="Tab Icons" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource HeaderBrush}" Margin="0,24,0,0" />
            <TextBlock Text="Pick a monster icon for each tab. Each monster can only be used once."
                       Foreground="{StaticResource MutedTextBrush}" FontStyle="Italic" FontSize="12" />

            <ItemsControl ItemsSource="{x:Bind IconVm.Rows}" Margin="0,6,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TabIconRow">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Title}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}" />
                            <ComboBox Grid.Column="1" Width="250" MaxDropDownHeight="360"
                                      ItemsSource="{x:Bind Options}"
                                      SelectedItem="{x:Bind Selected, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MonsterOption">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Image Width="22" Height="22" Stretch="Uniform"
                                                   Source="{x:Bind Id, Converter={StaticResource MonsterIcon}}" />
                                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
