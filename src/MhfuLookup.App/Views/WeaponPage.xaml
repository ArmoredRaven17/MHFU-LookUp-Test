<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.WeaponPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:ctl="using:MhfuLookup.App.Controls"
    xmlns:toolkit="using:AK.Toolkit.WinUI3"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="WLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,3" />
        </Style>
        <Style x:Key="WValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0,3" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Wide enough to fit the deepest/longest tree row (incl. cross-type leaves like
                 "Liquid Fire Blade (Long Sword)" ~10 levels deep) without horizontal scrolling. -->
            <ColumnDefinition Width="440" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource PanelBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ComboBox Grid.Row="0" Margin="8" HorizontalAlignment="Stretch"
                      ItemsSource="{x:Bind ViewModel.Types}"
                      SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}" />
            <TextBox x:Name="SearchBox" Grid.Row="1" Margin="8,0,8,8"
                     PlaceholderText="Search weapons…" TextChanged="SearchBox_TextChanged" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="8,0,8,8">
                <Button Content="Expand" Click="ExpandAll_Click" />
                <Button Content="Collapse" Click="CollapseAll_Click" />
                <Button x:Name="FilterButton" Content="Filter…" Click="Filter_Click" />
                <Button x:Name="SongsButton" Content="Songs…" Click="Songs_Click" Visibility="Collapsed" />
                <Button x:Name="AmmoButton" Content="Ammo…" Click="Ammo_Click" Visibility="Collapsed" />
                <Button x:Name="ShotTypesButton" Content="Shot Types…" Click="ShotTypes_Click" Visibility="Collapsed" />
                <Button x:Name="ShellsButton" Content="Shells…" Click="Shells_Click" Visibility="Collapsed" />
            </StackPanel>
            <!-- Unbound mode: nodes are populated from code-behind (Tree.RootNodes) so the
                 node API can drive Expand/Collapse All. The template's DataContext is the
                 TreeViewNode, so bind through Content.* (classic Binding, not x:Bind). -->
            <!-- Horizontal scroll so deep/long node names (e.g. "Hunter's Power Bow IV") stay
                 reachable rather than being clipped under the always-visible vertical bar. -->
            <muxc:TreeView x:Name="Tree" Grid.Row="3" SelectionMode="Single" ItemInvoked="Tree_ItemInvoked"
                           toolkit:ScrollBarExtensions.KeepVerticalExpanded="True"
                           ScrollViewer.HorizontalScrollMode="Enabled"
                           ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <muxc:TreeView.ItemTemplate>
                    <DataTemplate>
                        <!-- Branch-line guides drawn into the indentation gutter (negative left
                             margin = -depth*16) so the name stays at the normal content position. -->
                        <Grid>
                            <ItemsControl ItemsSource="{Binding Content.Guides}" Margin="{Binding Content.GutterMargin}"
                                          HorizontalAlignment="Left" VerticalAlignment="Stretch" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="16">
                                            <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                            <Rectangle Grid.Row="0" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                                       Fill="{StaticResource MutedTextBrush}"
                                                       Visibility="{Binding Converter={StaticResource GuidePart}, ConverterParameter=top}" />
                                            <Rectangle Grid.Row="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                                       Fill="{StaticResource MutedTextBrush}"
                                                       Visibility="{Binding Converter={StaticResource GuidePart}, ConverterParameter=bottom}" />
                                            <Rectangle Grid.Row="0" Height="1" Width="8" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                       Fill="{StaticResource MutedTextBrush}"
                                                       Visibility="{Binding Converter={StaticResource GuidePart}, ConverterParameter=horiz}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Image Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                                       Source="{Binding Content.IconUri, Converter={StaticResource ImageUri}}"
                                       Visibility="{Binding Content.IconUri, Converter={StaticResource StringToVis}}" />
                                <TextBlock Text="{Binding Content.Name}" VerticalAlignment="Center"
                                           Foreground="{Binding Content.Foreground}"
                                           FontStyle="{Binding Content.FontStyle}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </muxc:TreeView.ItemTemplate>
            </muxc:TreeView>
        </Grid>

        <ScrollViewer Grid.Column="1" Background="{StaticResource TableBgBrush}" Padding="16" toolkit:ScrollBarExtensions.KeepVerticalExpanded="True">
            <StackPanel>
                <TextBlock Text="Select a weapon from the tree."
                           Foreground="{StaticResource MutedTextBrush}"
                           Visibility="{x:Bind ViewModel.Detail, Mode=OneWay, Converter={StaticResource NullToVisible}}" />

                <StackPanel Visibility="{x:Bind ViewModel.Detail, Mode=OneWay, Converter={StaticResource NullToVis}}"
                            Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,6">
                        <Image Width="40" Height="40" Stretch="Uniform" VerticalAlignment="Center"
                               Source="{x:Bind ViewModel.Detail.IconUri, Mode=OneWay, Converter={StaticResource ImageUri}}" />
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.Detail.Name, Mode=OneWay}"
                                           FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center" />
                                <ctl:BookmarkStar x:Name="WeaponStar" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.Detail.Type, Mode=OneWay}"
                                       FontSize="14" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Rarity (tier-coloured) -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasRarity, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rarity" Style="{StaticResource WLabel}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Detail.RarityText, Mode=OneWay}"
                                   Style="{StaticResource WValue}" FontWeight="SemiBold"
                                   Foreground="{x:Bind ViewModel.Detail.RarityBrush, Mode=OneWay}" />
                    </Grid>

                    <!-- Attack (displayed value, with True Raw in parentheses) -->
                    <Grid ToolTipService.ToolTip="Displayed Value (True Raw)">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Attack" Style="{StaticResource WLabel}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Detail.AttackText, Mode=OneWay}" Style="{StaticResource WValue}" />
                    </Grid>

                    <!-- Element / status (colour-coded; displayed value with True Value in parentheses) -->
                    <Grid ToolTipService.ToolTip="Displayed Value (True Value)"
                          Visibility="{x:Bind ViewModel.Detail.HasElements, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Element" Style="{StaticResource WLabel}" />
                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.Detail.Elements, Mode=OneWay}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="12" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ElementChip">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Padding="0,3" VerticalAlignment="Center">
                                        <Image Source="{x:Bind IconUri, Converter={StaticResource ImageUri}}" Width="20" Height="20"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind IconUri, Converter={StaticResource StringToVis}}" />
                                        <TextBlock Text="{x:Bind Text}" Foreground="{x:Bind Color}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Slots -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Slots" Style="{StaticResource WLabel}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Detail.SlotsText, Mode=OneWay}" Style="{StaticResource WValue}" />
                    </Grid>

                    <!-- Other stats (Affinity, Defense, Shelling, Reload, Recoil, Notes) -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Stats, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:StatPair">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Label}" Style="{StaticResource WLabel}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Value}" Style="{StaticResource WValue}" Foreground="{x:Bind ValueBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Rapid Fire (Light Bowgun) — each ammo coloured to match its ammo colour -->
                    <Grid Margin="0,2,0,2"
                          Visibility="{x:Bind ViewModel.Detail.HasRapidFire, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rapid Fire" Style="{StaticResource WLabel}" VerticalAlignment="Top" />
                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.Detail.RapidFire, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChargeChip">
                                    <TextBlock Text="{x:Bind Text}" Foreground="{x:Bind Color}"
                                               FontWeight="SemiBold" FontSize="14" Padding="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Ammo loadout (bowguns): name per row, level per column, colour-coded names -->
                    <StackPanel Margin="0,4,0,2"
                                Visibility="{x:Bind ViewModel.Detail.HasAmmo, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Ammo" Style="{StaticResource WLabel}" />
                        <Grid Margin="0,1,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" /><ColumnDefinition Width="46" />
                                <ColumnDefinition Width="46" /><ColumnDefinition Width="46" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Lv1" Foreground="{StaticResource HeaderBrush}" FontSize="11" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Lv2" Foreground="{StaticResource HeaderBrush}" FontSize="11" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Lv3" Foreground="{StaticResource HeaderBrush}" FontSize="11" HorizontalAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Ammo, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AmmoGroup">
                                    <StackPanel Margin="0,2,0,4">
                                        <TextBlock Text="{x:Bind Header}" Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,1" />
                                        <ItemsControl ItemsSource="{x:Bind Lines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AmmoLine">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" /><ColumnDefinition Width="46" />
                                                            <ColumnDefinition Width="46" /><ColumnDefinition Width="46" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                                                   Foreground="{x:Bind NameColor}" FontWeight="SemiBold" FontSize="13" Padding="0,1" />
                                                        <TextBlock Grid.Column="1" Text="{x:Bind L1}" Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" HorizontalAlignment="Center" Padding="0,1" />
                                                        <TextBlock Grid.Column="2" Text="{x:Bind L2}" Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" HorizontalAlignment="Center" Padding="0,1" />
                                                        <TextBlock Grid.Column="3" Text="{x:Bind L3}" Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" HorizontalAlignment="Center" Padding="0,1" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Charges (bow shot types) -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasCharges, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Charges" Style="{StaticResource WLabel}" />
                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.Detail.Charges, Mode=OneWay}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="8" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChargeChip">
                                    <TextBlock Text="{x:Bind Text}" Foreground="{x:Bind Color}" FontWeight="SemiBold" FontSize="14" Padding="0,3" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Coatings (bow) -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasCoatings, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Coatings" Style="{StaticResource WLabel}" />
                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.Detail.Coatings, Mode=OneWay}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="8" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CoatingChip">
                                    <!-- Boosted coatings get a colour-tinted glow pill + bold. -->
                                    <Border Background="{x:Bind Background}" CornerRadius="8" Padding="7,2" Margin="0,1">
                                        <TextBlock Text="{x:Bind Text}" Foreground="{x:Bind Color}" FontWeight="{x:Bind Weight}" FontSize="14" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Sharpness -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasSharpness, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sharpness" Style="{StaticResource WLabel}" />
                        <ItemsControl Grid.Column="1" VerticalAlignment="Center" ItemsSource="{x:Bind ViewModel.Detail.Sharpness, Mode=OneWay}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SharpSegment">
                                    <Rectangle Width="{x:Bind Width}" Height="14" Fill="{x:Bind Color, Converter={StaticResource HexToBrush}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Sharpness +1 -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasSharpnessPlus, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sharp +1" Style="{StaticResource WLabel}" />
                        <ItemsControl Grid.Column="1" VerticalAlignment="Center" ItemsSource="{x:Bind ViewModel.Detail.SharpnessPlus, Mode=OneWay}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SharpSegment">
                                    <Rectangle Width="{x:Bind Width}" Height="14" Fill="{x:Bind Color, Converter={StaticResource HexToBrush}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Hunting Horn note colours (icon per note) -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasNoteIcons, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Notes" Style="{StaticResource WLabel}" VerticalAlignment="Center" />
                        <ItemsControl Grid.Column="1" VerticalAlignment="Center" ItemsSource="{x:Bind ViewModel.Detail.NoteIcons, Mode=OneWay}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NoteIcon">
                                    <Image Source="{x:Bind Uri, Converter={StaticResource ImageUri}}" Width="20" Height="20" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Hunting Horn songs this horn can play -->
                    <StackPanel Margin="0,4,0,2"
                                Visibility="{x:Bind ViewModel.Detail.HasSongs, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Songs" Style="{StaticResource WLabel}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Songs, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SongRow">
                                    <Grid Margin="0,2,0,3">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="92" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <ItemsControl Grid.Column="0" VerticalAlignment="Top" ItemsSource="{x:Bind Sequence}">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="2" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:NoteIcon">
                                                    <Image Source="{x:Bind Uri, Converter={StaticResource ImageUri}}" Width="18" Height="18" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{x:Bind Title}" Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap" />
                                            <TextBlock Text="{x:Bind EncoreText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasEncore, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Materials (upgrade / primary recipe) — one icon + quantity per row -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasMaterials, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Materials" Style="{StaticResource WLabel}" VerticalAlignment="Top" />
                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.Detail.MaterialItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MaterialItem">
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                                               Source="{x:Bind Icon, Converter={StaticResource ItemIcon}}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Text}" Style="{StaticResource WValue}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Create (M): alternative create-from-scratch recipe -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasCreateMaterials, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Create" Style="{StaticResource WLabel}" VerticalAlignment="Top" />
                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.Detail.CreateMaterialItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MaterialItem">
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                                               Source="{x:Bind Icon, Converter={StaticResource ItemIcon}}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Text}" Style="{StaticResource WValue}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Price (under Materials) -->
                    <Grid Visibility="{x:Bind ViewModel.Detail.HasPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Price" Style="{StaticResource WLabel}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Detail.PriceText, Mode=OneWay}" Style="{StaticResource WValue}" />
                    </Grid>

                    <!-- Editable user notes -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Notes" Style="{StaticResource WLabel}" />
                        <TextBox x:Name="WeaponNotesBox" PlaceholderText="Add your own notes…"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70" MaxHeight="200"
                                 TextChanged="WeaponNotesBox_TextChanged" LostFocus="WeaponNotesBox_LostFocus" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
