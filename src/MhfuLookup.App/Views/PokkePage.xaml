<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.PokkePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:app="using:MhfuLookup.App"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Farm areas -->
        <ListView Grid.Column="0" Background="{StaticResource PanelBgBrush}"
                  ItemsSource="{x:Bind ViewModel.Areas}"
                  SelectedItem="{x:Bind ViewModel.SelectedArea, Mode=TwoWay}"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PokkeArea">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                               Source="{x:Bind IconUri, Converter={StaticResource ImageUri}}" />
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{x:Bind Name}" VerticalAlignment="Center" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Obtainable items, all upgrade tiers stacked -->
        <ScrollViewer Grid.Column="1" Background="{StaticResource TableBgBrush}" Padding="16,12,16,16"
                      app:ScrollBarFix.KeepVerticalExpandedOwn="True"
                      HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Visible">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PokkeGroup">
                        <StackPanel Margin="0,0,0,14">
                            <!-- Tier header -->
                            <TextBlock Margin="0,0,0,4">
                                <Run Text="{x:Bind Label}" FontWeight="SemiBold"
                                     Foreground="{StaticResource HeaderBrush}" />
                            </TextBlock>
                            <TextBlock Text="{x:Bind Note}" FontSize="12" Margin="0,-4,0,4"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Visibility="{x:Bind HasNote, Converter={StaticResource BoolToVis}}" />
                            <!-- Items -->
                            <ItemsControl ItemsSource="{x:Bind Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PokkeEntry">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                            <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                                   Source="{x:Bind Icon, Converter={StaticResource ImageUri}}" />
                                            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                                <Run Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}" />
                                                <Run Text="{x:Bind NoteText}" Foreground="{StaticResource MutedTextBrush}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
