<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.MonsterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MhfuLookup.App.Models"
    xmlns:core="using:MhfuLookup.Core.Data"
    xmlns:app="using:MhfuLookup.App"
    xmlns:ctl="using:MhfuLookup.App.Controls"
    xmlns:toolkit="using:AK.Toolkit.WinUI3"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Left: search + grouped monster list ── -->
        <Grid Grid.Column="0" Background="{StaticResource PanelBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBox x:Name="SearchBox" Grid.Row="0" Margin="8"
                     PlaceholderText="Search monsters…" TextChanged="SearchBox_TextChanged" />
            <ListView x:Name="MonsterList" Grid.Row="1"
                      SelectionMode="Single" SelectionChanged="MonsterList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="core:MonsterSummary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Width="26" Height="26" Stretch="Uniform" VerticalAlignment="Center"
                                   Source="{x:Bind Id, Converter={StaticResource MonsterIcon}}" />
                            <TextBlock Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="local:MonsterGroup"
                                          xmlns:local="using:MhfuLookup.App.ViewModels">
                                <TextBlock Text="{x:Bind Type}" FontWeight="Bold"
                                           Foreground="{StaticResource HeaderBrush}"
                                           Margin="0,6,0,2" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
        </Grid>

        <!-- ── Right: detail (pinned header + scrolling body) ── -->
        <Grid Grid.Column="1" Background="{StaticResource TableBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Select a monster from the list." Padding="16"
                       Foreground="{StaticResource MutedTextBrush}"
                       Visibility="{x:Bind ViewModel.Detail, Mode=OneWay, Converter={StaticResource NullToVisible}}" />

            <!-- Pinned header: icon + name + type stay visible while the body scrolls. -->
            <Border Grid.Row="0" Background="Transparent" Padding="16,16,16,10"
                    Visibility="{x:Bind ViewModel.Detail, Mode=OneWay, Converter={StaticResource NullToVis}}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Image Width="56" Height="56" Stretch="Uniform" VerticalAlignment="Center"
                           Source="{x:Bind ViewModel.Detail.Id, Mode=OneWay, Converter={StaticResource MonsterIcon}}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Detail.Name, Mode=OneWay}"
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.Detail.Type, Mode=OneWay}"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <ctl:BookmarkStar x:Name="MonsterStar" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" Background="Transparent" Padding="16,0,16,16" app:ScrollBarFix.KeepVerticalExpandedOwn="True">
                <StackPanel Visibility="{x:Bind ViewModel.Detail, Mode=OneWay, Converter={StaticResource NullToVis}}">

                    <!-- Hitzones (colour-coded by value) -->
                    <StackPanel Visibility="{x:Bind ViewModel.Detail.HasHitzones, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Hitzones" Style="{StaticResource SectionTitle}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled" app:ScrollForwarder.BubbleVerticalWheel="True" app:ScrollBarFix.KeepHorizontalExpandedOwn="True" Padding="0,0,0,18">
                        <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="48" /><ColumnDefinition Width="48" /><ColumnDefinition Width="48" />
                                <ColumnDefinition Width="48" /><ColumnDefinition Width="48" /><ColumnDefinition Width="56" />
                                <ColumnDefinition Width="48" /><ColumnDefinition Width="56" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Part" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="Cut" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="2" Text="Bash" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="3" Text="Shot" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="4" Text="Fire" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="5" Text="Watr" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="6" Text="Thndr" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="7" Text="Ice" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="8" Text="Drgn" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="9" Text="KO" Style="{StaticResource HeaderCell}" />
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Hitzones, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Hitzone">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="48" /><ColumnDefinition Width="48" /><ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="48" /><ColumnDefinition Width="48" /><ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="48" /><ColumnDefinition Width="56" /><ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Part}" Foreground="{StaticResource TextBrush}" FontSize="12" Padding="6,3" />
                                        <Border Grid.Column="1" Background="{x:Bind Cut, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Cut}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="2" Background="{x:Bind Bash, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Bash}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="3" Background="{x:Bind Shot, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Shot}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="4" Background="{x:Bind Fire, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Fire}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="5" Background="{x:Bind Water, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Water}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="6" Background="{x:Bind Thunder, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Thunder}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="7" Background="{x:Bind Ice, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Ice}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="8" Background="{x:Bind Dragon, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Dragon}" Style="{StaticResource NumCell}" /></Border>
                                        <Border Grid.Column="9" Background="{x:Bind Ko, Converter={StaticResource HitzoneBrush}}"><TextBlock Text="{x:Bind Ko}" Style="{StaticResource NumCell}" /></Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Stagger -->
                    <StackPanel Visibility="{x:Bind ViewModel.Detail.HasStaggers, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Stagger Limits" Style="{StaticResource SectionTitle}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Staggers, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:StaggerRow">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" /><ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Part}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Limit}" Style="{StaticResource BodyCell}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Ailments -->
                    <StackPanel Visibility="{x:Bind ViewModel.Detail.HasAilments, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Ailment Tolerances" Style="{StaticResource SectionTitle}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled" app:ScrollForwarder.BubbleVerticalWheel="True" app:ScrollBarFix.KeepHorizontalExpandedOwn="True" Padding="0,0,0,18">
                        <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" /><ColumnDefinition Width="64" /><ColumnDefinition Width="70" />
                                <ColumnDefinition Width="60" /><ColumnDefinition Width="70" /><ColumnDefinition Width="64" /><ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ailment" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="Initial" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="2" Text="Increase" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="3" Text="Max" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="4" Text="Duration" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="5" Text="Damage" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="6" Text="Recovery" Style="{StaticResource HeaderCell}" />
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Ailments, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:AilmentRow">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" /><ColumnDefinition Width="64" /><ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="60" /><ColumnDefinition Width="70" /><ColumnDefinition Width="64" /><ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Ailment}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Initial}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Increase}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Max}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind Duration}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="5" Text="{x:Bind Damage}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="6" Text="{x:Bind Recovery}" Style="{StaticResource BodyCell}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Items -->
                    <StackPanel Visibility="{x:Bind ViewModel.Detail.HasItems, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Items" Style="{StaticResource SectionTitle}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Items, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MonsterItemRow">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" /><ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Item}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Effect}" Style="{StaticResource BodyCell}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Notes}" Style="{StaticResource BodyCell}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Loot sections: Carve / Capture / Break, each with tier columns -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.LootSections, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:LootSectionGroup">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Header}" Style="{StaticResource SectionTitle}" />
                                    <ItemsControl ItemsSource="{x:Bind Parts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:LootPart">
                                                <StackPanel Margin="0,2,0,10">
                                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="{x:Bind ConditionDisplay}" FontStyle="Italic" FontSize="11"
                                                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                                                               Visibility="{x:Bind HasCondition, Converter={StaticResource BoolToVis}}" />
                                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto"
                                                                  VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled" app:ScrollForwarder.BubbleVerticalWheel="True"
                                                                  app:ScrollBarFix.KeepHorizontalExpandedOwn="True" Margin="0,4,0,0" Padding="0,0,0,18">
                                                        <ItemsControl ItemsSource="{x:Bind Tiers}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="models:LootTierColumn">
                                                                    <StackPanel Width="180" Margin="0,0,12,0">
                                                                        <TextBlock Text="{x:Bind TierLabel}" FontSize="11"
                                                                                   Foreground="{StaticResource HeaderBrush}"
                                                                                   Margin="0,0,0,2" />
                                                                        <ItemsControl ItemsSource="{x:Bind Rows}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate x:DataType="models:LootRow">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*" /><ColumnDefinition Width="44" />
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" Text="{x:Bind Item}"
                                                                                                   Foreground="{StaticResource TextBrush}" FontSize="12" Padding="0,1" TextWrapping="Wrap" />
                                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Pct}"
                                                                                                   Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                                                                                   HorizontalAlignment="Right" Padding="0,1" />
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Monster Facts (renamed from "Notes" to avoid confusion with the editable notes below) -->
                    <StackPanel Visibility="{x:Bind ViewModel.Detail.HasNotes, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Monster Facts" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="{x:Bind ViewModel.Detail.Notes, Mode=OneWay}"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Editable user notes -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Notes" Style="{StaticResource SectionTitle}" />
                        <TextBox x:Name="MonsterNotesBox" PlaceholderText="Add your own notes…"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" MaxHeight="220"
                                 TextChanged="MonsterNotesBox_TextChanged" LostFocus="MonsterNotesBox_LostFocus" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
