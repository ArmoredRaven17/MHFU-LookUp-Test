<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.QuestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:core="using:MhfuLookup.Core.Data"
    xmlns:ctl="using:MhfuLookup.App.Controls"
    xmlns:toolkit="using:AK.Toolkit.WinUI3"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource PanelBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ComboBox x:Name="CategoryCombo" Grid.Row="0" Margin="8" HorizontalAlignment="Stretch"
                      ItemsSource="{x:Bind ViewModel.Categories}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="core:NamedDoc">
                        <TextBlock Text="{x:Bind Title}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ListView x:Name="QuestList" Grid.Row="1" SelectionMode="Single"
                      SelectionChanged="QuestList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuestItem">
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{x:Bind TargetIds}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="2" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Image Width="20" Height="20" Stretch="Uniform"
                                                   Source="{x:Bind Converter={StaticResource MonsterIcon}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{x:Bind TargetItemIcons}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="2" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Image Width="20" Height="20" Stretch="Uniform"
                                                   Source="{x:Bind Converter={StaticResource ItemIcon}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Border Grid.Column="2" Background="#B8860B" CornerRadius="3" Padding="5,1" VerticalAlignment="Center"
                                    Visibility="{x:Bind KeyOnly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="KEY" Foreground="White" FontSize="9" FontWeight="Bold" />
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource NegativeBrush}" CornerRadius="3" Padding="5,1" VerticalAlignment="Center"
                                    Visibility="{x:Bind Urgent, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="URGENT" Foreground="White" FontSize="9" FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="vm:QuestRankGroup">
                                <!-- Training categories use an empty label → no section header (flat list). -->
                                <TextBlock Text="{x:Bind Label}" FontWeight="Bold"
                                           Foreground="{StaticResource HeaderBrush}" Margin="0,6,0,2"
                                           Visibility="{x:Bind Label, Converter={StaticResource StringToVis}}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
        </Grid>

        <!-- Right: detail (pinned header + scrolling body) -->
        <Grid Grid.Column="1" Background="{StaticResource TableBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Select a quest." Padding="16"
                       Foreground="{StaticResource MutedTextBrush}"
                       Visibility="{x:Bind ViewModel.Selected, Mode=OneWay, Converter={StaticResource NullToVisible}}" />

            <!-- Pinned header: quest name + KEY/URGENT badges stay visible while the body scrolls. -->
            <Border Grid.Row="0" Background="Transparent" Padding="16,16,16,10"
                    Visibility="{x:Bind ViewModel.Selected, Mode=OneWay, Converter={StaticResource NullToVis}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- Target icons (same as the quest list): monster(s) and/or delivery items -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.Selected.HasTargets, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Selected.TargetIds, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Image Width="36" Height="36" Stretch="Uniform"
                                           Source="{x:Bind Converter={StaticResource MonsterIcon}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Selected.TargetItemIcons, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Image Width="36" Height="36" Stretch="Uniform"
                                           Source="{x:Bind Converter={StaticResource ItemIcon}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.Selected.Name, Mode=OneWay}"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" />
                    <ctl:BookmarkStar x:Name="QuestStar" />
                    <!-- Badge colours match the list pane: gold KEY, red URGENT. -->
                    <Border Background="#B8860B" CornerRadius="3" Padding="6,2"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.Selected.KeyOnly, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="KEY" Foreground="White" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <Border Background="{StaticResource NegativeBrush}" CornerRadius="3" Padding="6,2"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.Selected.Urgent, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="URGENT" Foreground="White" FontSize="10" FontWeight="Bold" />
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" Background="Transparent" Padding="16,0,16,16" toolkit:ScrollBarExtensions.KeepVerticalExpanded="True">
                <StackPanel Visibility="{x:Bind ViewModel.Selected, Mode=OneWay, Converter={StaticResource NullToVis}}">

                    <StackPanel Margin="0,4,0,0" Spacing="4">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Objective" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Selected.Objective, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        </Grid>
                        <!-- Danger: training quest star rating (★ count; G-prefixed for G-rank). -->
                        <Grid ColumnSpacing="10"
                              Visibility="{x:Bind ViewModel.Selected.HasDanger, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Danger" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Selected.Danger, Mode=OneWay}"
                                       Foreground="{StaticResource HeaderBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnSpacing="10"
                              Visibility="{x:Bind ViewModel.Selected.HasEnvironment, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Environment" Style="{StaticResource HeaderCell}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border CornerRadius="3" Padding="7,1" Background="{StaticResource PositiveBrush}"
                                        Visibility="{x:Bind ViewModel.Selected.IsStable, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Stable" Foreground="White" FontSize="11" FontWeight="Bold" />
                                </Border>
                                <Border CornerRadius="3" Padding="7,1" Background="{StaticResource NegativeBrush}"
                                        Visibility="{x:Bind ViewModel.Selected.IsUnstable, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Unstable" Foreground="White" FontSize="11" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Location" Style="{StaticResource HeaderCell}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <Image Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                                       Source="{x:Bind ViewModel.Selected.Location, Mode=OneWay, Converter={StaticResource LocationIcon}}" />
                                <TextBlock Text="{x:Bind ViewModel.Selected.Location, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{x:Bind ViewModel.Selected.Location, Mode=OneWay, Converter={StaticResource LocationBrush}}" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10"
                              Visibility="{x:Bind ViewModel.Selected.HasTimeOfDay, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Time" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Selected.TimeOfDay, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Time Limit" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Selected.Time, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Contract Fee" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Selected.Fee, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Reward" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Selected.Reward, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Text="Monsters" Style="{StaticResource SectionTitle}"
                               Visibility="{x:Bind ViewModel.Selected.HasMonsters, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{x:Bind ViewModel.Selected.MonstersText, Mode=OneWay}" Style="{StaticResource BodyCell}"
                               Visibility="{x:Bind ViewModel.Selected.HasMonsters, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <TextBlock Text="Description" Style="{StaticResource SectionTitle}"
                               Visibility="{x:Bind ViewModel.Selected.HasDescription, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{x:Bind ViewModel.Selected.Description, Mode=OneWay}" Style="{StaticResource BodyCell}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.Selected.HasDescription, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <!-- Weapon Selection (Training School): a weapon choice per Expander -->
                    <TextBlock Text="Weapon Selection" Style="{StaticResource SectionTitle}"
                               Visibility="{x:Bind ViewModel.Selected.HasLoadouts, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Selected.Loadouts, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.Selected.HasLoadouts, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuestLoadout">
                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,2">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind WeaponType}" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" />
                                            <TextBlock Text="{x:Bind Weapon}" Foreground="{StaticResource TextBrush}" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{x:Bind Description}" FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Visibility="{x:Bind HasDescription, Converter={StaticResource BoolToVis}}" />
                                        <Grid ColumnSpacing="8"
                                              Visibility="{x:Bind HasSet, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Set" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource HeaderBrush}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind SetText}" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" />
                                        </Grid>
                                        <Grid ColumnSpacing="8"
                                              Visibility="{x:Bind HasActiveSkills, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="86" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Active Skills" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{StaticResource HeaderBrush}" VerticalAlignment="Top" />
                                            <!-- One skill per line; green = beneficial, red = negative skill to avoid. -->
                                            <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ActiveSkills}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:QuestSkill">
                                                        <TextBlock Text="{x:Bind Name}" Foreground="{x:Bind Color}"
                                                                   FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        <StackPanel Margin="0,2,0,0"
                                                    Visibility="{x:Bind HasItems, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Items" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource HeaderBrush}" />
                                            <ItemsControl ItemsSource="{x:Bind Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:QuestSupply">
                                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1">
                                                            <Image Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                                                                   Source="{x:Bind Icon, Converter={StaticResource ItemIcon}}" />
                                                            <TextBlock Text="{x:Bind Text}" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Rewards" Style="{StaticResource SectionTitle}"
                               Visibility="{x:Bind ViewModel.Selected.HasRewards, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Selected.Rewards, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.Selected.HasRewards, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuestReward">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1">
                                    <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                           Source="{x:Bind Icon, Converter={StaticResource ItemIcon}}" />
                                    <TextBlock Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Notes" Style="{StaticResource SectionTitle}"
                               Visibility="{x:Bind ViewModel.Selected.HasNotes, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{x:Bind ViewModel.Selected.Notes, Mode=OneWay}" Style="{StaticResource BodyCell}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.Selected.HasNotes, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <TextBlock Text="{x:Bind ViewModel.Selected.Unlock, Mode=OneWay}" FontStyle="Italic"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.Selected.HasUnlock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <!-- Editable user notes -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Notes" Style="{StaticResource SectionTitle}" />
                        <TextBox x:Name="QuestNotesBox" PlaceholderText="Add your own notes…"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70" MaxHeight="200"
                                 TextChanged="QuestNotesBox_TextChanged" LostFocus="QuestNotesBox_LostFocus" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
