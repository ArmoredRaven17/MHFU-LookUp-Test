<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.AwardsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:app="using:MhfuLookup.App"
    Background="{StaticResource WindowBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox" Grid.Row="0" Margin="16,12,16,8" Width="320" HorizontalAlignment="Left"
                 PlaceholderText="Search awards…" TextChanged="SearchBox_TextChanged" />

        <ScrollViewer Grid.Row="1" Padding="16,0,16,16"
                      app:ScrollBarFix.KeepVerticalExpandedOwn="True"
                      HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Visible">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Awards}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AwardView">
                        <Grid Padding="0,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Width="52" Height="52" Stretch="Uniform" VerticalAlignment="Top"
                                   Source="{x:Bind IconUri, Converter={StaticResource ImageUri}}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind Description}" Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind Condition}" Foreground="{StaticResource PositiveBrush}"
                                           TextWrapping="Wrap" Margin="0,1,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
