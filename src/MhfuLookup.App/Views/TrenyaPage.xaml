<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.TrenyaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:app="using:MhfuLookup.App"
    xmlns:ctl="using:MhfuLookup.App.Controls"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Destinations -->
        <ListView Grid.Column="0" Background="{StaticResource PanelBgBrush}"
                  ItemsSource="{x:Bind ViewModel.Locations}"
                  SelectedItem="{x:Bind ViewModel.SelectedLocation, Mode=TwoWay}"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TrenyaLocation">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                               Source="{x:Bind Name, Converter={StaticResource LocationIcon}}" />
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{x:Bind Name}" VerticalAlignment="Center" TextWrapping="Wrap"
                                   Foreground="{x:Bind Name, Converter={StaticResource LocationBrush}}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Column="1" Background="{StaticResource TableBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Tier picker: how many Pokke Points to fund Trenya with, + mechanic note -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="16,12,16,8">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.SelectedLocationName, Mode=OneWay}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                    <ctl:BookmarkStar x:Name="TrenyaStar" VerticalAlignment="Center" />
                    <TextBlock Text="Pokke Points" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource HeaderBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <ComboBox Width="200" VerticalAlignment="Center"
                              ItemsSource="{x:Bind ViewModel.Tiers}" DisplayMemberPath="Label"
                              SelectedItem="{x:Bind ViewModel.SelectedTier, Mode=TwoWay}" />
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.75" Foreground="{StaticResource TextBrush}"
                           Text="Each return brings several items (more at higher Pokke Points). Within a category, items are drawn uniformly at random — every item listed is equally likely, so Trenya has no per-item drop rates." />
            </StackPanel>

            <!-- Category → items Trenya brings back at the selected tier -->
            <ScrollViewer Grid.Row="1" Padding="16,0,16,12"
                          app:ScrollBarFix.KeepVerticalExpandedOwn="True"
                          HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Visible">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CategoryGroup">
                            <Grid BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Category}" Style="{StaticResource HeaderCell}"
                                           VerticalAlignment="Top" />
                                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TrenyaItem">
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,3">
                                                <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                                       Source="{x:Bind Icon, Converter={StaticResource ImageUri}}" />
                                                <TextBlock Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}"
                                                           VerticalAlignment="Center" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
