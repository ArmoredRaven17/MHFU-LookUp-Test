<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.BookmarksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:toolkit="using:AK.Toolkit.WinUI3"
    Background="{StaticResource WindowBgBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Bookmarks" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="13" TextWrapping="Wrap"
                       Text="Star a monster, weapon, item, armor set, decoration, quest or treasure on its page, then click it here to jump straight back to it." />
        </StackPanel>

        <TextBlock Grid.Row="1" VerticalAlignment="Top" Margin="0,12,0,0"
                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                   Text="No bookmarks yet — tap the bookmark icon on any monster, weapon, item, armor set, armor skill, decoration, quest, treasure, gathering area or Trenya destination to add one."
                   Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

        <ListView x:Name="List" Grid.Row="1" SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="List_ItemClick"
                  toolkit:ScrollBarExtensions.KeepVerticalExpanded="True">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:BookmarkEntry">
                    <Grid ColumnSpacing="10" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center"
                               Source="{x:Bind IconUri, Converter={StaticResource ImageUri}}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button Grid.Column="2" Content="✕" Click="Remove_Click" Tag="{x:Bind}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource MutedTextBrush}" FontSize="14"
                                VerticalAlignment="Center" ToolTipService.ToolTip="Remove bookmark" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="vm:BookmarkGroup">
                            <TextBlock Text="{x:Bind Header}" FontWeight="Bold"
                                       Foreground="{StaticResource HeaderBrush}" Margin="0,8,0,2" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
        </ListView>
    </Grid>
</Page>
