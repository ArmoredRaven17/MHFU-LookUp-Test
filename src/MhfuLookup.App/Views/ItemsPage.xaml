<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.ItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:core="using:MhfuLookup.Core.Data"
    xmlns:ctl="using:MhfuLookup.App.Controls"
    xmlns:toolkit="using:AK.Toolkit.WinUI3"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: search + grouped item list -->
        <Grid Grid.Column="0" Background="{StaticResource PanelBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ComboBox x:Name="CategoryJump" Grid.Row="0" Margin="8,8,8,0" HorizontalAlignment="Stretch"
                      PlaceholderText="Jump to category…"
                      ItemsSource="{x:Bind ViewModel.Groups}"
                      SelectionChanged="CategoryJump_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ItemCategoryGroup">
                        <TextBlock Text="{x:Bind Category}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox x:Name="SearchBox" Grid.Row="1" Margin="8"
                     PlaceholderText="Search items…" TextChanged="SearchBox_TextChanged" />
            <ListView x:Name="ItemList" Grid.Row="2"
                      SelectionMode="Single" SelectionChanged="ItemList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="core:ItemRow">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                   Source="{x:Bind Icon, Converter={StaticResource ItemIcon}}" />
                            <TextBlock Text="{x:Bind Name}" Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                            <!-- Gatherable marker -->
                            <Image Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"
                                   Source="ms-appx:///Assets/Misc/gather_icon_green.png"
                                   ToolTipService.ToolTip="Gatherable"
                                   Visibility="{x:Bind Converter={StaticResource GatherableVis}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="vm:ItemCategoryGroup">
                                <TextBlock Text="{x:Bind Category}" FontWeight="Bold" TextWrapping="Wrap"
                                           Foreground="{StaticResource HeaderBrush}" Margin="0,6,12,2" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
        </Grid>

        <!-- Right: detail -->
        <ScrollViewer Grid.Column="1" Background="{StaticResource TableBgBrush}" Padding="16" toolkit:ScrollBarExtensions.KeepVerticalExpanded="True">
            <StackPanel>
                <TextBlock Text="Select an item."
                           Foreground="{StaticResource MutedTextBrush}"
                           Visibility="{x:Bind ViewModel.Selected, Mode=OneWay, Converter={StaticResource NullToVisible}}" />

                <StackPanel Visibility="{x:Bind ViewModel.Selected, Mode=OneWay, Converter={StaticResource NullToVis}}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Image Width="48" Height="48" Stretch="Uniform" VerticalAlignment="Center"
                               Source="{x:Bind ViewModel.Selected.Icon, Mode=OneWay, Converter={StaticResource ItemIcon}}" />
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind ViewModel.Selected.Name, Mode=OneWay}"
                                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Image Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                       Source="ms-appx:///Assets/Misc/gather_icon_green.png" ToolTipService.ToolTip="Gatherable"
                                       Visibility="{x:Bind ViewModel.HasGathering, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.Selected.Category, Mode=OneWay}"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                        <ctl:BookmarkStar x:Name="ItemStar" />
                    </StackPanel>

                    <Grid Margin="0,14,0,0" ColumnSpacing="10" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Rarity" Style="{StaticResource HeaderCell}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.Selected.Rarity, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Capacity" Style="{StaticResource HeaderCell}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.Selected.Capacity, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Value" Style="{StaticResource HeaderCell}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.Selected.Value, Mode=OneWay}" Style="{StaticResource BodyCell}" />
                        <!-- Pokke Value: Account Items only -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Pokke Value" Style="{StaticResource HeaderCell}"
                                   Visibility="{x:Bind ViewModel.Selected.PokkeValue, Mode=OneWay, Converter={StaticResource StringToVis}}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.Selected.PokkeValue, Mode=OneWay}" Style="{StaticResource BodyCell}"
                                   Visibility="{x:Bind ViewModel.Selected.PokkeValue, Mode=OneWay, Converter={StaticResource StringToVis}}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Description" Style="{StaticResource HeaderCell}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.Selected.Description, Mode=OneWay}" Style="{StaticResource BodyCell}" TextWrapping="Wrap" />
                    </Grid>

                    <!-- Where the item can be gathered (area / rank / rate), when applicable -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{x:Bind ViewModel.HasGathering, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Gathered From" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" /><ColumnDefinition Width="120" />
                                <ColumnDefinition Width="60" /><ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Location" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="1" Text="Area" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="2" Text="Rank" Style="{StaticResource HeaderCell}" />
                            <TextBlock Grid.Column="3" Text="Rate" Style="{StaticResource HeaderCell}" />
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.GatherSources, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GatherSource">
                                    <Border Background="{x:Bind Alt, Converter={StaticResource AltRowBrush}}" CornerRadius="3" Padding="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" /><ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="60" /><ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Location}" Style="{StaticResource BodyCell}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Area}" Style="{StaticResource BodyCell}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind Rank}" Style="{StaticResource BodyCell}" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Rate}" Style="{StaticResource BodyCell}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
