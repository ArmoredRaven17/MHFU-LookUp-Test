<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MhfuLookup.App.Views.VeggieElderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MhfuLookup.App.ViewModels"
    xmlns:app="using:MhfuLookup.App"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Search + zones -->
        <Grid Grid.Column="0" Background="{StaticResource PanelBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" Grid.Row="0" Margin="8,12,8,8"
                     PlaceholderText="Search items…" TextChanged="SearchBox_TextChanged" />

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Zones}"
                      SelectedItem="{x:Bind ViewModel.SelectedZone, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" VerticalAlignment="Center" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Trades in the selected zone -->
        <Grid Grid.Column="1" Background="{StaticResource TableBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title + how-it-works notes -->
            <StackPanel Grid.Row="0" Margin="16,12,16,6">
                <TextBlock Text="{x:Bind ViewModel.ResultTitle, Mode=OneWay}"
                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                           Text="Hand the Veggie Elder an item and he returns another. He'll trade 1–6 times per visit (Felyne Charisma guarantees 6), and has a ~20% chance to give the Rare result instead of the Common one (Felyne Negotiation raises this)." />
            </StackPanel>

            <!-- Column header -->
            <Grid Grid.Row="1" Margin="16,4,16,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Item" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" />
                <TextBlock Grid.Column="1" Text="Common Trade" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" />
                <TextBlock Grid.Column="2" Text="Rare Trade" FontWeight="SemiBold" Foreground="{StaticResource HeaderBrush}" />
            </Grid>

            <ScrollViewer Grid.Row="2" Padding="16,0,16,16" app:ScrollBarFix.KeepVerticalExpandedOwn="True"
                          HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Visible">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Trades}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:VeggieTrade">
                            <Border Background="{x:Bind Alt, Converter={StaticResource AltRowBrush}}"
                                    CornerRadius="3" Padding="0,4" Margin="0,0,0,1">
                            <StackPanel>
                            <!-- Zone tag (search results only) -->
                            <TextBlock Text="{x:Bind Zone}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,1"
                                       Foreground="{StaticResource HeaderBrush}"
                                       Visibility="{x:Bind ShowZone, Converter={StaticResource BoolToVis}}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Item handed over -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,8,0">
                                    <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                           Source="{x:Bind ItemIcon, Converter={StaticResource ImageUri}}" />
                                    <TextBlock Text="{x:Bind Item}" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextBrush}" />
                                </StackPanel>

                                <!-- Common result -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,8,0">
                                    <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                           Source="{x:Bind CommonIcon, Converter={StaticResource ImageUri}}" />
                                    <TextBlock Text="{x:Bind Common}" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextBrush}" />
                                </StackPanel>

                                <!-- Rare result (blank for trades with none) -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                            Visibility="{x:Bind HasRare, Converter={StaticResource BoolToVis}}">
                                    <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"
                                           Source="{x:Bind RareIcon, Converter={StaticResource ImageUri}}" />
                                    <TextBlock Text="{x:Bind Rare}" VerticalAlignment="Center" TextWrapping="Wrap"
                                               Foreground="{StaticResource HeaderBrush}" />
                                </StackPanel>
                            </Grid>
                            </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- No-results message -->
            <TextBlock Grid.Row="2" Margin="16,8,16,0" Foreground="{StaticResource MutedTextBrush}"
                       Text="No trades match your search." TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.NoResults, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</Page>
